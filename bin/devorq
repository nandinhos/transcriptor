#!/bin/bash
# DEVORQ - CLI Principal
# Orquestrador de desenvolvimento orientado a skills

set -eEo pipefail

DEVORQ_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DEVORQ_DIR="$DEVORQ_ROOT/.devorq"

# Cores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log() { echo -e "${CYAN}[DEVORQ]${NC} $1"; }
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}✓${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# Carregar módulos
source "$DEVORQ_ROOT/lib/detect.sh"
source "$DEVORQ_ROOT/lib/lessons.sh"
source "$DEVORQ_ROOT/lib/handoff.sh"

# =====================================================
# COMANDOS
# =====================================================

cmd_init() {
    log "🚀 Inicializando DEVORQ..."
    
    # Criar estrutura
    mkdir -p "$DEVORQ_DIR/state"/{checkpoints,session-audits,spec-exports,lessons-learned,brainstorms,contracts,specs}
    mkdir -p "$DEVORQ_DIR/rules"
    mkdir -p "$DEVORQ_DIR/docs"
    
    # Detectar contexto
    local stack=$(detect_stack "$DEVORQ_ROOT")
    local project_type=$(detect_project_type "$DEVORQ_ROOT")
    local llm=$(detect_llm)
    local runtime=$(detect_runtime)
    local db=$(detect_database)
    
    log_info "Stack: $stack"
    log_info "Tipo: $project_type"
    log_info "LLM: $llm"
    log_info "Runtime: $runtime"
    log_info "Banco: $db"
    
    # Detectar PRD
    local prd=$(check_prd_exists "$DEVORQ_ROOT")
    if [ -n "$prd" ]; then
        log_info "PRD: $prd"
    else
        log_info "PRD: não encontrado"
    fi
    
    # Detectar legado
    if is_legacy "$DEVORQ_ROOT"; then
        log_warn "Sistema LEGADO detectado"
    fi
    
    # Salvar state
    cat > "$DEVORQ_DIR/state/session.json" << EOF
{
  "stack": "$stack",
  "project_type": "$project_type",
  "llm": "$llm",
  "runtime": "$runtime",
  "database": "$db",
  "prd": "$prd",
  "initialized_at": "$(date -Iseconds)",
  "version": "1.0.0-dev"
}
EOF
    
    # Criar regras do projeto
    establish_project_rules "$project_type" "$stack"
    
    log_success "DEVORQ inicializado!"
}

establish_project_rules() {
    local project_type="$1"
    local stack="$2"
    
    case "$project_type" in
        "greenfield")
            cat > "$DEVORQ_DIR/rules/project.md" << EOF
# Regras do Projeto - Greenfield

## Contexto
- Tipo: Sistema novo
- Stack: $stack
- Regra: Arquitetura primeiro, código depois

## Regras de Ouro
1. TDD Obrigatório
2. PRD como fonte de verdade
3. Code Review antes de merge

## Padrões
- Estrutura: MVC padrão
- Testes: Feature tests
- Linter: Pint
EOF
            ;;
        "brownfield")
            cat > "$DEVORQ_DIR/rules/project.md" << EOF
# Regras do Projeto - Brownfield

## Contexto
- Tipo: Projeto em andamento
- Stack: $stack
- Regra: "First, do no harm"

## Regras de Ouro
1. Consistência com padrões existentes
2. TDD para novas funcionalidades
3. Minimalismo
4. Documentar com /learned-lesson
EOF
            ;;
    esac
}

cmd_flow() {
    shift
    local intent="$1"
    
    if [ -z "$intent" ]; then
        log_error "Intent necessário. Uso: devorq flow 'minha task'"
        exit 1
    fi
    
    # Executar fluxo completo
    bash "$DEVORQ_ROOT/lib/orchestration/flow.sh" flow "$intent"
}

cmd_agent() {
    log "=== DEVORQ AGENT MODE ==="
    echo ""
    
    # Mostrar contexto atual
    local stack=$(detect_stack "$DEVORQ_ROOT")
    local project_type=$(detect_project_type "$DEVORQ_ROOT")
    local llm=$(detect_llm)
    local runtime=$(detect_runtime)
    
    cat << EOF
Stack:     $stack
Tipo:      $project_type
LLM:       $llm
Runtime:   $runtime
Versão:    $(cat "$DEVORQ_ROOT/VERSION")

## Fluxo Completo:
1. /env-context     → Detectar contexto automaticamente
2. /scope-guard     → Contrato de escopo (OBRIGATÓRIO)
3. /pre-flight      → Validar tipos/enums
4. /schema-validate → Validar banco
5. tdd              → RED → GREEN → REFACTOR
6. /quality-gate    → Checklist (OBRIGATÓRIO)
7. /session-audit   → Métricas (OBRIGATÓRIO)
8. checkpoint       → Para continuidade

## Para iniciar uma task:
  devorq flow "implementar feature X"
EOF
}

cmd_context() {
    export_context
}

cmd_checkpoint() {
    local timestamp=$(date +%Y%m%d_%H%M%S)
    local checkpoint_dir="$DEVORQ_DIR/state/checkpoints"
    
    mkdir -p "$checkpoint_dir"
    
    local git_status=""
    if git rev-parse --git-dir > /dev/null 2>&1; then
        git_status=$(git status --short 2>/dev/null | head -10)
    fi
    
    cat > "$checkpoint_dir/cp_${timestamp}.md" << EOF
# Checkpoint - $timestamp

## Git Status
\`\`\`
$git_status
\`\`\`

## Contexto
- Stack: $(detect_stack "$DEVORQ_ROOT")
- Tipo: $(detect_project_type "$DEVORQ_ROOT")
- LLM: $(detect_llm)
EOF
    
    log_success "Checkpoint: cp_${timestamp}.md"
}

cmd_info() {
    cat << EOF
=== DEVORQ CONTEXT ===
Stack:     $(detect_stack "$DEVORQ_ROOT")
Tipo:      $(detect_project_type "$DEVORQ_ROOT")
LLM:       $(detect_llm)
Runtime:   $(detect_runtime)
Banco:     $(detect_database)
Versão:    $(cat "$DEVORQ_ROOT/VERSION")
EOF
}

cmd_skills() {
    echo "Skills DEVORQ ($(ls -1 "$DEVORQ_DIR/skills/" 2>/dev/null | wc -l | tr -d ' ') skills):"
    for skill_dir in "$DEVORQ_DIR/skills"/*/; do
        local skill
        skill=$(basename "$skill_dir")
        local version=""
        if [ -f "$skill_dir/CHANGELOG.md" ]; then
            version=$(grep -o 'v[0-9]\+\.[0-9]\+\.[0-9]\+' "$skill_dir/CHANGELOG.md" 2>/dev/null | head -1)
        fi
        echo "  - $skill ${version:-v?}"
    done
}

# =====================================================
# LIÇÕES
# =====================================================

cmd_lessons() {
    local subcmd="${2:-list}"
    case "$subcmd" in
        list)
            lessons_list "$DEVORQ_DIR"
            ;;
        validate)
            lessons_validate "$DEVORQ_DIR"
            ;;
        apply)
            lessons_apply "$DEVORQ_DIR" "${3:-}"
            ;;
        *)
            log_error "Subcomando desconhecido: $subcmd"
            echo "Uso: devorq lessons <list|validate|apply> [nome]"
            exit 1
            ;;
    esac
}

# =====================================================
# HANDOFF
# =====================================================

cmd_handoff() {
    local subcmd="${2:-status}"
    case "$subcmd" in
        generate)
            log "Gerando handoff file..."
            local handoff_file
            handoff_file=$(generate_handoff "$DEVORQ_DIR" "$DEVORQ_ROOT")
            log_success "Handoff gerado: $handoff_file"
            echo ""
            echo "[Gate 4] Revisar o handoff antes de passar para o próximo LLM:"
            echo ""
            cat "$handoff_file"
            echo ""
            echo "Arquivo: $handoff_file"
            ;;
        status)
            handoff_status "$DEVORQ_DIR"
            ;;
        list)
            handoff_list "$DEVORQ_DIR"
            ;;
        update)
            handoff_update_status "$DEVORQ_DIR" "${3:-em_andamento}"
            ;;
        *)
            log_error "Subcomando desconhecido: $subcmd"
            echo "Uso: devorq handoff <generate|status|list|update>"
            exit 1
            ;;
    esac
}

# =====================================================
# SKILL (versioning e rollback)
# =====================================================

cmd_skill() {
    local subcmd="${2:-list}"
    case "$subcmd" in
        rollback)
            local skill_name="${3:-}"
            local target_version="${4:-}"
            if [ -z "$skill_name" ] || [ -z "$target_version" ]; then
                echo "Uso: devorq skill rollback <nome_skill> <versao>"
                echo "Exemplo: devorq skill rollback scope-guard v1.0.0"
                exit 1
            fi
            skill_rollback "$DEVORQ_DIR/skills" "$skill_name" "$target_version"
            ;;
        version)
            local skill_name="${3:-}"
            local bump_type="${4:-minor}"
            if [ -z "$skill_name" ]; then
                echo "Uso: devorq skill version <nome_skill> <patch|minor|major>"
                exit 1
            fi
            version_skill "$DEVORQ_DIR/skills" "$skill_name" "$bump_type"
            ;;
        versions)
            local skill_name="${3:-}"
            if [ -z "$skill_name" ]; then
                echo "Uso: devorq skill versions <nome_skill>"
                exit 1
            fi
            local versions_dir="$DEVORQ_DIR/skills/$skill_name/VERSIONS"
            if [ -d "$versions_dir" ]; then
                echo "Versões disponíveis para $skill_name:"
                ls -1 "$versions_dir" | sed 's/.md$//' | sed 's/^/  /'
            else
                echo "Nenhuma versão encontrada para $skill_name"
            fi
            ;;
        *)
            log_error "Subcomando desconhecido: $subcmd"
            echo "Uso: devorq skill <rollback|version|versions>"
            exit 1
            ;;
    esac
}

cmd_upgrade() {
    local target="${2:-}"

    if [ -z "$target" ]; then
        log_error "Informe o caminho do projeto a atualizar."
        echo "Uso: devorq upgrade <caminho_do_projeto>"
        echo "Exemplo: devorq upgrade ~/projects/meu-projeto"
        exit 1
    fi

    target="$(realpath "$target")"

    if [ ! -d "$target" ]; then
        log_error "Diretório não encontrado: $target"
        exit 1
    fi

    log "Atualizando DEVORQ em: $target"

    # Garantir que bin/ e lib/ existam no destino
    mkdir -p "$target/bin" "$target/lib"

    # Copiar CLI
    cp "$DEVORQ_ROOT/bin/devorq" "$target/bin/devorq"
    cp "$DEVORQ_ROOT/bin/devorq-prompt" "$target/bin/devorq-prompt" 2>/dev/null || true
    chmod +x "$target/bin/devorq"

    # Copiar apenas os módulos shell (não sobrescrever .py específicos do projeto)
    for f in "$DEVORQ_ROOT/lib"/*.sh; do
        cp "$f" "$target/lib/"
    done

    # Copiar subdiretório orchestration se existir
    if [ -d "$DEVORQ_ROOT/lib/orchestration" ]; then
        mkdir -p "$target/lib/orchestration"
        cp "$DEVORQ_ROOT/lib/orchestration/"*.sh "$target/lib/orchestration/" 2>/dev/null || true
    fi

    log_success "DEVORQ atualizado em: $target"
    log_info "Execute './bin/devorq init' no projeto para reinicializar o contexto."
}

cmd_help() {
    cat << EOF
DEVORQ v2.0 — Orquestrador de Desenvolvimento Multi-LLM

Uso: devorq <comando> [opcoes]

Comandos principais:
  init                          Inicializar projeto (detectar stack, tipo, regras)
  flow <intent>                 Executar fluxo completo para uma task
  agent                         Mostrar modo de agente ativo
  context                       Mostrar contexto detectado
  checkpoint                    Criar checkpoint de continuidade
  info                          Mostrar info resumida
  skills                        Listar skills disponíveis com versões
  upgrade <path>                Atualizar DEVORQ instalado em outro projeto

Handoff multi-LLM:
  handoff generate              Gerar spec padronizada para próximo LLM (Gate 4)
  handoff status                Mostrar status do handoff atual
  handoff list                  Listar histórico de handoffs
  handoff update <status>       Atualizar status (em_andamento|aguardando_merge|concluido)

Pipeline de aprendizado:
  lessons list                  Listar lições pendentes, validadas e aplicadas
  lessons validate              Exibir lições para validação via Context7 (Gate 6)
  lessons apply <nome>          Aplicar lição numa skill (Gate 7)

Versionamento de skills:
  skill rollback <skill> <v>    Reverter skill para versão anterior
  skill version <skill> <bump>  Criar snapshot de nova versão (patch|minor|major)
  skill versions <skill>        Listar versões disponíveis de uma skill

Fluxo obrigatório (v2.0):
  1. devorq init
  2. /scope-guard            [Gate 1: aprovar contrato]
  3. /pre-flight             [Gate 2: aprovar antes de implementar]
  4. devorq handoff generate [Gate 4: aprovar antes de trocar LLM]
  5. TDD RED->GREEN->REFACTOR
  6. /quality-gate           [Gate 3: aprovar antes de commitar]
  7. /session-audit
  8. /learned-lesson         [Gate 5: salvar lições?]
  9. devorq lessons validate [Gate 6: validação Context7]
 10. devorq lessons apply    [Gate 7: aplicar nas skills]
EOF
}

# =====================================================
# MAIN
# =====================================================

case "${1:-help}" in
    init)        cmd_init ;;
    flow)        cmd_flow "$@" ;;
    agent)       cmd_agent ;;
    context)     cmd_context ;;
    checkpoint)  cmd_checkpoint ;;
    info)        cmd_info ;;
    skills)      cmd_skills ;;
    lessons)     cmd_lessons "$@" ;;
    handoff)     cmd_handoff "$@" ;;
    skill)       cmd_skill "$@" ;;
    upgrade)     cmd_upgrade "$@" ;;
    help|--help|-h) cmd_help ;;
    *)           log_error "Comando desconhecido: $1"; cmd_help; exit 1 ;;
esac